{
  "name": "fiori-yapster-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Freestyle SAPUI5 Yapster-inspired demo with OData mockserver and OPA tests.",
  "scripts": {
    "start": "ui5 serve --config ui5-mock.yaml -o index.html",
    "start:plain": "ui5 serve -o index.html",
    "build": "ui5 build --clean-dest",
    "test:opa": "karma start",
    "test": "npm run test:opa -- --single-run"
  },
  "devDependencies": {
    "@sap-ux/ui5-middleware-fe-mockserver": "2.4.11",
    "@ui5/cli": "4.0.51",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-ui5": "4.1.0",
    "playwright": "^1.53.0"
  }
}
